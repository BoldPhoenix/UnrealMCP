{
  "mcpServers": {
    "unrealmcp": {
      "command": "C:/Projects/UnrealMCP/.venv/Scripts/python.exe",
      "args": ["-m", "unreal_mcp"],
      "env": {
        "UNREAL_PROJECT_DIR": "C:/Path/To/YourUEProject",
        "UNREAL_UPROJECT": "C:/Path/To/YourUEProject/YourProject.uproject",
        "UNREAL_EDITOR_EXE": "C:/Program Files/Epic Games/UE_5.7/Engine/Binaries/Win64/UnrealEditor.exe"
      }
    }
  }
}
